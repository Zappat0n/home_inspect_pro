<div class="w-full max-w-md mx-auto">
  <h2 class="text-3xl font-bold text-gray-900 mb-6 text-center"><%= t("devise.views.registrations.edit.title", resource: resource_name.to_s.humanize) %></h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <div class="bg-yellow-50 border border-yellow-200 text-yellow-800 px-4 py-3 rounded-md">
        <%= t("devise.views.registrations.edit.pending_confirmation", email: resource.unconfirmed_email) %>
      </div>
    <% end %>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <p class="text-xs text-gray-500 mb-1"><%= t("devise.views.registrations.edit.password_hint") %></p>
      <%= f.password_field :password,
            autocomplete: "new-password",
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      <% if @minimum_password_length %>
        <p class="text-xs text-gray-500 mt-1"><%= t("devise.views.registrations.edit.password_minimum", count: @minimum_password_length) %></p>
      <% end %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password_confirmation,
            autocomplete: "new-password",
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= f.label :current_password, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <p class="text-xs text-gray-500 mb-1"><%= t("devise.views.registrations.edit.current_password_hint") %></p>
      <%= f.password_field :current_password,
            autocomplete: "current-password",
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= f.submit t("devise.views.registrations.edit.submit"),
            class: "btn btn-primary w-full" %>
    </div>
  <% end %>

  <div class="mt-8 pt-6 border-t border-gray-200">
    <h3 class="text-lg font-medium text-gray-900 mb-3"><%= t("devise.views.registrations.edit.cancel_account") %></h3>
    <p class="text-sm text-gray-600 mb-3">
      <%= t("devise.views.registrations.edit.unhappy") %>
      <%= button_to t("devise.views.registrations.edit.cancel_account"),
            registration_path(resource_name),
            data: { confirm: t("devise.views.registrations.edit.cancel_account_confirm"), turbo_confirm: t("devise.views.registrations.edit.cancel_account_confirm") },
            method: :delete,
            class: "text-red-600 hover:text-red-800 font-medium" %>
    </p>
  </div>

  <div class="mt-6 text-center">
    <%= link_to t("devise.views.links.back"), :back, class: "text-sm text-blue-600 hover:text-blue-800" %>
  </div>
</div>
