<div class="w-full max-w-md mx-auto">
  <h2 class="text-3xl font-bold text-gray-900 mb-6 text-center"><%= t("devise.views.sessions.title") %></h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password,
            autocomplete: "current-password",
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center">
        <%= f.check_box :remember_me, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        <%= f.label :remember_me, t("devise.views.sessions.remember_me"), class: "ml-2 block text-sm text-gray-700" %>
      </div>
    <% end %>

    <div>
      <%= f.submit t("devise.views.sessions.submit"),
            class: "btn btn-primary w-full" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
