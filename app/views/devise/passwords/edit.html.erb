<div class="w-full max-w-md mx-auto">
  <h2 class="text-3xl font-bold text-gray-900 mb-6 text-center"><%= t("devise.views.passwords.edit.title") %></h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= f.hidden_field :reset_password_token %>

    <div>
      <%= f.label :password, t("devise.views.passwords.edit.password_label"), class: "form-label" %>
      <% if @minimum_password_length %>
        <p class="text-xs text-gray-500 mb-1"><%= t("devise.views.mailers.password_reset.password_hint", count: @minimum_password_length) %></p>
      <% end %>
      <%= f.password_field :password,
            autofocus: true,
            autocomplete: "new-password",
            class: "form-input" %>
    </div>

    <div>
      <%= f.label :password_confirmation, t("devise.views.passwords.edit.password_confirmation_label"), class: "form-label" %>
      <%= f.password_field :password_confirmation,
            autocomplete: "new-password",
            class: "form-input" %>
    </div>

    <div>
      <%= f.submit t("devise.views.passwords.edit.submit"),
            class: "btn btn-primary w-full" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
