<div class="w-full max-w-md mx-auto">
  <h2 class="text-3xl font-bold text-gray-900 mb-6 text-center"><%= t("devise.views.passwords.title") %></h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= f.submit t("devise.views.passwords.submit"),
            class: "btn btn-primary w-full" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
