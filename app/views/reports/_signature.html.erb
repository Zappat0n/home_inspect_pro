<%# locals: (inspection:) %>
<% if inspection.signature_data.present? %>
  <div class="page-break">
    <h2 style="font-size: 16px; font-weight: 700; margin: 0 0 16px 0; color: #111827;">
      <%= t("reports.show.signature") %>
    </h2>

    <div style="border: 1px solid #d1d5db; border-radius: 4px; padding: 16px; display: inline-block;">
      <%= image_tag inspection.signature_data,
                    alt: t("reports.show.signature_alt"),
                    style: "max-width: 300px; max-height: 100px;" %>
    </div>

    <p style="margin-top: 12px; font-size: 10px; color: #6b7280;">
      <%= t("reports.show.date") %>: <%= l(inspection.completed_at.presence || inspection.created_at, format: :long) %>
    </p>
  </div>
<% end %>
