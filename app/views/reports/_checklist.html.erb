<%# locals: (inspection:, items_grouped:) %>
<div>
  <% items_grouped.each do |category_name, items| %>
    <div class="avoid-break" style="margin-bottom: 16px;">
      <h3 style="font-size: 13px; font-weight: 700; margin: 0 0 8px 0; color: #374151; text-transform: uppercase; letter-spacing: 0.5px;">
        <%= category_name %>
      </h3>

      <% items.each do |inspection_item| %>
        <% checklist_item = inspection_item.checklist_item %>
        <div style="padding: 6px 0; border-bottom: 1px solid #f3f4f6;">
          <div style="display: flex; align-items: flex-start; gap: 8px;">
            <div style="flex: 1;">
              <span style="font-weight: 600; font-size: 11px; color: #111827;">
                <%= checklist_item.name %>
              </span>

              <% if checklist_item.description.present? %>
                <p style="margin: 2px 0 0 0; font-size: 10px; color: #6b7280;">
                  <%= checklist_item.description %>
                </p>
              <% end %>

              <% if inspection_item.defect? && inspection_item.comment.present? %>
                <p style="margin: 4px 0 0 0; font-size: 10px; color: #dc2626; font-style: italic;">
                  <%= inspection_item.comment %>
                </p>
              <% end %>

              <% photos = inspection.inspection_photos.where(checklist_item: checklist_item).ordered %>
              <% if photos.any? %>
                <div style="margin-top: 6px; display: flex; flex-wrap: wrap; gap: 6px;">
                  <% photos.each do |photo| %>
                    <%= image_tag photo.photo.variant(resize_to_limit: [200, 200]),
                                  alt: checklist_item.name,
                                  style: "width: 80px; height: 80px; object-fit: cover; border: 1px solid #e5e7eb; border-radius: 4px;" %>
                  <% end %>
                </div>
              <% end %>
            </div>

            <div style="flex-shrink: 0;">
              <% if inspection_item.ok? %>
                <span style="display: inline-block; padding: 1px 8px; font-size: 10px; font-weight: 600; color: #059669; border: 1px solid #059669; border-radius: 4px;">
                  &#10003; <%= t("inspection_items.status.ok") %>
                </span>
              <% elsif inspection_item.defect? %>
                <span style="display: inline-block; padding: 1px 8px; font-size: 10px; font-weight: 600; color: #dc2626; border: 1px solid #dc2626; border-radius: 4px;">
                  &#10007; <%= t("inspection_items.status.defect") %>
                </span>
              <% elsif inspection_item.na? %>
                <span style="display: inline-block; padding: 1px 8px; font-size: 10px; font-weight: 600; color: #6b7280; border: 1px solid #9ca3af; border-radius: 4px;">
                  &mdash; <%= t("inspection_items.status.na") %>
                </span>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
