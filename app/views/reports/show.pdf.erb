<%# locals: (inspection:, items_grouped:, defects:) %>
<div class="report-pdf">
  <%= render "reports/header", inspection: inspection %>

  <%= render "reports/checklist", inspection: inspection, items_grouped: items_grouped %>

  <%= render "reports/defects_summary", defects: defects %>

  <%= render "reports/signature", inspection: inspection %>

  <%= render "reports/footer" %>
</div>
