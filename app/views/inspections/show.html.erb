<div class="max-w-3xl mx-auto inspections">
  <div class="mb-6">
    <%= link_to inspections_path,
                class: "link font-medium" do %>
      &larr; <%= t("inspections.new.cancel") %>
    <% end %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-8">
    <%= t("inspections.show.title") %>
  </h1>

  <div class="card divide-y divide-gray-200 mb-8">
    <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
      <dt class="text-sm font-medium text-gray-500">
        <%= t("inspections.show.property_address") %>
      </dt>
      <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
        <%= inspection.property_address %>
      </dd>
    </div>

    <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
      <dt class="text-sm font-medium text-gray-500">
        <%= t("inspections.show.client_name") %>
      </dt>
      <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
        <%= inspection.client_name %>
      </dd>
    </div>

    <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
      <dt class="text-sm font-medium text-gray-500">
        <%= t("inspections.show.client_email") %>
      </dt>
      <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
        <%= inspection.client_email %>
      </dd>
    </div>

    <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
      <dt class="text-sm font-medium text-gray-500">
        <%= t("inspections.show.template") %>
      </dt>
      <dd class="mt-1 text-sm text-s-gray-900 sm:col-span-2 sm:mt-0">
        <%= inspection.inspection_template.name %>
      </dd>
    </div>

    <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
      <dt class="text-sm font-medium text-gray-500">
        <%= t("inspections.show.status") %>
      </dt>
      <dd class="mt-1 sm:col-span-2 sm:mt-0">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
          <%= inspection.draft? ? "bg-amber-100 text-amber-800" : "bg-green-100 text-green-800" %>">
          <%= t("inspections.show.statuses.#{inspection.status}") %>
        </span>
      </dd>
    </div>

    <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
      <dt class="text-sm font-medium text-gray-500">
        <%= t("inspections.show.created_at") %>
      </dt>
      <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
        <%= l(inspection.created_at, format: :long) %>
      </dd>
    </div>
  </div>

  <% if inspection.completed? %>
    <div class="mb-8">
      <%= link_to t("inspections.show.view_pdf"),
                  report_inspection_path(inspection),
                  'data-testid': "view-pdf-button",
                  class: "btn",
                  target: "_blank" %>
    </div>
  <% end %>

  <% if inspection.signature_data.present? %>
    <div class="card p-6 mb-8">
      <h3 class="text-lg font-semibold text-gray-900 mb-2">
        <%= t("inspections.show.signature") %>
      </h3>
      <%= image_tag inspection.signature_data, 
        alt: t("inspections.show.signature_alt"),
        class: "max-h-32 border border-gray-200 rounded" %>
    </div>
  <% end %>

  <% if inspection.draft? %>
    <div class="mb-8">
      <%= form_with(
            url: complete_inspection_path(inspection),
            method: :patch,
            data: {
              controller: "signature-pad",
              action: "submit->signature-pad#capture",
            },
          ) do |form| %>
        <div class="card p-6 mb-4">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">
            <%= t("inspections.complete.signature_title") %>
          </h3>
          <p class="text-sm text-gray-500 mb-4">
            <%= t("inspections.complete.signature_hint") %>
          </p>

          <canvas data-signature-pad-target="canvas"
                  width="600"
                  height="200"
                  class="w-full border border-gray-300 rounded-lg touch-none cursor-crosshair bg-white"></canvas>

          <input type="hidden"
                 data-signature-pad-target="signatureInput"
                 name="inspection[signature_data]">

          <div class="mt-3 flex gap-3">
            <button type="button"
                    data-action="signature-pad#clear"
                    class="btn btn-outline"
                    data-testid="clear-signature-button">
              <%= t("inspections.complete.clear_signature") %>
            </button>
          </div>
        </div>

        <%= form.submit(
              t("inspections.complete.button"),
              data: {
                testid: "complete-inspection-button",
                turbo_confirm: t("inspections.complete.confirm"),
              },
              class: "btn btn-success",
            ) %>
      <% end %>
    </div>
  <% end %>

  <div class="space-y-8">
    <% inspection_items.group_by { |item| item.checklist_item.category }.each do |category, items| %>
      <div>
        <h2 class="text-lg font-semibold text-gray-900 mb-4 px-2">
          <%= category %>
        </h2>

        <div class="card divide-y divide-gray-200 overflow-hidden">
           <% items.each do |item| %>
            <%= render partial: "inspection_items/inspection_item",
                       locals: {
                         inspection: inspection,
                         inspection_item: item,
                       } %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
