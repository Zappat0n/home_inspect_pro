<div class="max-w-3xl mx-auto">
  <div class="mb-6">
    <%= link_to inspections_path,
                class: "text-sm text-blue-600 hover:text-blue-800 font-medium" do %>
      &larr; <%= t("inspections.new.cancel") %>
    <% end %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-8">
    <%= t("inspections.show.title") %>
  </h1>

  <div class="bg-white rounded-lg border border-gray-200 divide-y divide-gray-200 mb-8">
    <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
      <dt class="text-sm font-medium text-gray-500">
        <%= t("inspections.show.property_address") %>
      </dt>
      <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
        <%= inspection.property_address %>
      </dd>
    </div>

    <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
      <dt class="text-sm font-medium text-gray-500">
        <%= t("inspections.show.client_name") %>
      </dt>
      <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
        <%= inspection.client_name %>
      </dd>
    </div>

    <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
      <dt class="text-sm font-medium text-gray-500">
        <%= t("inspections.show.client_email") %>
      </dt>
      <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
        <%= inspection.client_email %>
      </dd>
    </div>

    <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
      <dt class="text-sm font-medium text-gray-500">
        <%= t("inspections.show.template") %>
      </dt>
      <dd class="mt-1 text-sm text-s-gray-900 sm:col-span-2 sm:mt-0">
        <%= inspection.inspection_template.name %>
      </dd>
    </div>

    <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
      <dt class="text-sm font-medium text-gray-500">
        <%= t("inspections.show.status") %>
      </dt>
      <dd class="mt-1 sm:col-span-2 sm:mt-0">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
          <%= inspection.draft? ? "bg-amber-100 text-amber-800" : "bg-green-100 text-green-800" %>">
          <%= t("inspections.show.statuses.#{inspection.status}") %>
        </span>
      </dd>
    </div>

    <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
      <dt class="text-sm font-medium text-gray-500">
        <%= t("inspections.show.created_at") %>
      </dt>
      <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
        <%= l(inspection.created_at, format: :long) %>
      </dd>
    </div>
  </div>

  <div class="space-y-8">
    <% inspection_items.group_by { |item| item.checklist_item.category }.each do |category, items| %>
      <div>
        <h2 class="text-lg font-semibold text-gray-900 mb-4 px-2">
          <%= category %>
        </h2>

        <div class="bg-white rounded-lg border border-gray-200 divide-y divide-gray-200 overflow-hidden">
          <% items.each do |item| %>
            <div class="p-4 sm:px-6 sm:py-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4" id="<%= dom_id(item) %>">
              <div class="flex-1">
                <p class="text-sm font-medium text-gray-900">
                  <%= item.checklist_item.name %>
                </p>
                <p class="text-xs text-gray-500 mt-1">
                  <%= item.checklist_item.description %>
                </p>
              </div>

               <div class="flex items-center gap-2">
                <%= form_with(
                      model: [inspection, item],
                      class: "flex gap-2",
                      data: {
                        controller: "inspection-item",
                        action: "change->inspection-item#statusChanged",
                      },
                    ) do |f| %>
                   <%= f.label :status, "ok", class: "px-3 py-1 text-xs font-medium rounded-full border cursor-pointer transition-colors
                    #{item.ok? ? "bg-green-600 text-white border-green-600" : "bg-white text-gray-600 border-gray-300 hover:bg-gray-50"}", data: { testid: "inspection-item-ok-status", inspection_item_target: "statusRadio", action: "click->inspection-item#statusChanged" } do %>
                     <%= f.radio_button :status, "ok", class: "hidden", checked: item.ok?, data: { inspection_item_target: "statusRadio" , action: "inspection-item#statusChanged"} %>
                     <%= I18n.t("inspection_items.status.ok") %>
                   <% end %>

                   <%= f.label :status, "defect", class: "px-3 py-1 text-xs font-medium rounded-full border cursor-pointer transition-colors
                    #{item.defect? ? "bg-red-600 text-white border-red-600" : "bg-white text-gray-600 border-gray-300 hover:bg-gray-50"}", data: { testid: "inspection-item-defect-status", inspection_item_target: "statusRadio", action: "click->inspection-item#statusChanged" } do %>
                     <%= f.radio_button :status, "defect", class: "hidden", checked: item.defect?, data: { inspection_item_target: "statusRadio" } %>
                     <%= I18n.t("inspection_items.status.defect") %>
                   <% end %>

                   <%= f.label :status, "na", class: "px-3 py-1 text-xs font-medium rounded-full border cursor-pointer transition-colors
                    #{item.na? ? "bg-gray-600 text-white border-gray-600" : "bg-white text-gray-600 border-gray-300 hover:bg-gray-50"}", data: { testid: "inspection-item-na-status", inspection_item_target: "statusRadio", action: "click->inspection-item#statusChanged" } do %>
                     <%= f.radio_button :status, "na", class: "hidden", checked: item.na?, data: { inspection_item_target: "statusRadio" } %>
                     <%= I18n.t("inspection_items.status.na") %>
                   <% end %>

                  <div class="mt-2 sm:mt-0 sm:ml-2 w-full sm:w-auto hidden" data-inspection-item-target="commentContainer">
                    <%= f.text_area(
                          :comment,
                          rows: 2,
                          class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm",
                          placeholder: I18n.t("inspection_items.comment.placeholder"),
                          data: { testid: "inspection-item-comment-textarea" },
                        ) %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
