<% if inspection.errors.any? %>
  <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-md mb-6">
    <h2 class="text-sm font-medium mb-2">
      <%= pluralize(inspection.errors.count, "error") %> prohibited this inspection from being saved:
    </h2>
    <ul class="list-disc list-inside space-y-1 text-sm">
      <% inspection.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with(model: inspection, url: inspections_path, class: "space-y-6") do |form| %>
  <div class="bg-white rounded-lg border border-gray-200 p-6 space-y-6">
    <div>
      <%= form.label :property_address,
                     t("inspections.form.property_address_label"),
                     class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :property_address,
                          class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
                          data: { testid: "property_address_field" } %>
    </div>

    <div>
      <%= form.label :client_name,
                     t("inspections.form.client_name_label"),
                     class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :client_name,
                          class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
                          data: { testid: "client_name_field" } %>
    </div>

    <div>
      <%= form.label :client_email,
                     t("inspections.form.client_email_label"),
                     class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.email_field :client_email,
                           class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
                           data: { testid: "client_email_field" } %>
    </div>

  </div>

  <div class="flex items-center gap-4">
    <%= form.submit t("inspections.new.submit"),
                    class: "btn btn-primary",
                    data: { testid: "submit_button" } %>
    <%= link_to t("inspections.new.cancel"),
                inspections_path,
                class: "text-sm font-medium text-gray-600 hover:text-gray-800",
                data: { testid: "cancel_link" } %>
  </div>
<% end %>
