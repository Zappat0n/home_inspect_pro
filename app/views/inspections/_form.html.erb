<% if inspection.errors.any? %>
  <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-md mb-6">
    <h2 class="text-sm font-medium mb-2">
      <%= pluralize(inspection.errors.count, "error") %> prohibited this inspection from being saved:
    </h2>
    <ul class="list-disc list-inside space-y-1 text-sm">
      <% inspection.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with(model: inspection, url: inspections_path, class: "space-y-6") do |form| %>
  <div class="card p-6 space-y-6">
    <div>
      <p class="form-label"><%= t("inspections.form.template_label") %></p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-2">
        <% templates.each do |template| %>
          <label class="relative block border rounded-lg p-4 cursor-pointer transition-colors has-[:checked]:border-teal-600 has-[:checked]:bg-teal-50 hover:border-gray-400">
            <%= form.radio_button :inspection_template_id, template.id,
                  checked: template == inspection.inspection_template,
                  class: "sr-only" %>
            <div class="flex items-start gap-3">
              <div class="flex-1 min-w-0">
                <p class="font-medium text-sm"><%= template.name %></p>
                <p class="text-xs text-gray-500 mt-1">
                  <%= t("inspections.form.template_item_count", count: template.items.count) %>
                </p>
              </div>
              <% if template.custom? %>
                <span class="text-xs px-2 py-0.5 rounded bg-purple-100 text-purple-700 shrink-0"
                      data-testid="custom-template-badge">
                  <%= t("inspections.form.template_custom_badge") %>
                </span>
              <% end %>
            </div>
          </label>
        <% end %>
      </div>
    </div>
    <div>
      <%= form.label :property_address,
                     t("inspections.form.property_address_label"),
                     class: "form-label" %>
      <%= form.text_field :property_address,
                          class: "form-input form-input-lg",
                          data: { testid: "property_address_field" } %>
    </div>

    <div>
      <%= form.label :client_name,
                     t("inspections.form.client_name_label"),
                     class: "form-label" %>
      <%= form.text_field :client_name,
                          class: "form-input form-input-lg",
                          data: { testid: "client_name_field" } %>
    </div>

    <div>
      <%= form.label :client_email,
                     t("inspections.form.client_email_label"),
                     class: "form-label" %>
      <%= form.email_field :client_email,
                           class: "form-input form-input-lg",
                           data: { testid: "client_email_field" } %>
    </div>

  </div>

  <div class="flex items-center gap-4">
    <%= form.submit t("inspections.new.submit"),
                    class: "btn btn-primary",
                    data: { testid: "submit_button" } %>
    <%= link_to t("inspections.new.cancel"),
                inspections_path,
                class: "text-sm font-medium text-gray-600 hover:text-gray-800",
                data: { testid: "cancel_link" } %>
  </div>
<% end %>
