<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">
      <%= t("inspections.index.title") %>
    </h1>
    <%= link_to t("inspections.index.new_button"),
                new_inspection_path,
                class: "btn btn-primary" %>
  </div>

  <% if inspections.empty? %>
    <div class="card text-center py-16">
      <p class="text-gray-500 mb-4"><%= t("inspections.index.empty") %></p>
      <%= link_to t("inspections.index.empty_cta"),
                  new_inspection_path,
                  class: "btn btn-primary btn-lg" %>
    </div>
  <% else %>
    <div class="space-y-4">
      <% inspections.each do |inspection| %>
        <%= link_to inspection_path(inspection),
                    class: "block card p-5 hover:shadow-md transition-shadow" do %>
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
            <div class="flex-1 min-w-0">
              <h3 class="text-lg font-semibold text-gray-900 truncate">
                <%= inspection.property_address %>
              </h3>
              <p class="text-sm text-gray-500 mt-1">
                <%= inspection.client_name %>
              </p>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                <%= inspection.draft? ? "bg-amber-100 text-amber-800" : "bg-green-100 text-green-800" %>">
                <%= t("inspections.show.statuses.#{inspection.status}") %>
              </span>
              <span class="text-sm text-gray-400 hidden sm:inline">
                <%= l(inspection.created_at.to_date, format: :default) %>
              </span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
