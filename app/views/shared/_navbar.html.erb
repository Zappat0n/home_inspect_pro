<nav class="bg-white shadow-sm border-b border-gray-200 fixed top-0 inset-x-0 z-10">
  <div class="container mx-auto px-5 py-3 flex items-center justify-between">
    <%= link_to t("app.name"), root_path, class: "font-semibold text-lg text-gray-900" %>
    <div class="flex items-center">
      <% if user_signed_in? %>
        <%= button_to t("devise.views.links.sign_out"), destroy_user_session_path, method: :delete, class: "px-4 py-2 bg-red-600 text-white text-sm font-medium rounded hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2" %>
      <% else %>
        <%= link_to t("devise.views.links.log_in"), new_user_session_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
        <%= link_to t("devise.views.links.sign_up"), new_user_registration_path, class: "ml-4 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded hover:bg-blue-700 cursor-pointer" %>
      <% end %>
    </div>
  </div>
</nav>
