<% form_frame_id = item.persisted? ? "#{dom_id(item)}_form" : "new_checklist_item_#{item.inspection_template_category.name.to_s.parameterize}" %>
<%= turbo_frame_tag form_frame_id do %>
  <%= form_with(
        url: item.persisted? ? inspection_template_item_path(template, item) : inspection_template_items_path(template),
        model: item,
        class: "space-y-3",
        data: { testid: "checklist-item-form" },
      ) do |form| %>

    <% if item.errors.any? %>
      <div data-testid="item-form-errors" class="text-red-600 text-sm">
        <%= item.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= form.label :name, t("checklist_items.form.name"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :name,
            class: "w-full border border-gray-300 rounded px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-transparent",
            data: { testid: "checklist-item-name-input" } %>
    </div>

    <div>
      <%= form.label :description, t("checklist_items.form.description"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_area :description,
            rows: 2,
            class: "w-full border border-gray-300 rounded px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-transparent",
            data: { testid: "checklist-item-description-input" } %>
    </div>

    <%= form.hidden_field :inspection_template_category_id %>

    <div>
      <%= form.label :severity, t("checklist_items.form.severity"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.select :severity,
            InspectionTemplate::Item.severities.keys.map { |s| [t("checklist_items.severity.#{s}"), s] },
            {},
            class: "w-full border border-gray-300 rounded px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-transparent",
            data: { testid: "checklist-item-severity-select" } %>
    </div>

    <div class="flex items-center gap-2">
      <%= form.check_box :allows_photo,
            class: "rounded border-gray-300" %>
      <%= form.label :allows_photo, t("checklist_items.form.allows_photo"), class: "text-sm text-gray-700" %>
    </div>

    <div class="flex gap-2">
      <%= form.submit t("checklist_items.form.submit"),
            class: "px-3 py-1.5 text-sm bg-blue-600 text-white rounded hover:bg-blue-700",
            data: { testid: "checklist-item-submit" } %>

      <% if inline %>
        <button type="button"
                class="px-3 py-1.5 text-sm bg-gray-100 text-gray-700 rounded hover:bg-gray-200"
                data-action="inline-edit#toggle"
                data-testid="checklist-item-cancel">
          <%= t("checklist_items.form.cancel") %>
        </button>
      <% else %>
        <button type="button"
                class="px-3 py-1.5 text-sm bg-gray-100 text-gray-700 rounded hover:bg-gray-200"
                data-action="collapse#close"
                data-testid="checklist-item-cancel">
          <%= t("checklist_items.form.cancel") %>
        </button>
      <% end %>
    </div>
  <% end %>
<% end %>
