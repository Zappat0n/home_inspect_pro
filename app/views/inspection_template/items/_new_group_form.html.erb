<details id="new_group_form" class="mt-6" data-testid="new-group-form">
  <summary class="text-sm text-blue-600 cursor-pointer hover:underline list-none font-medium" data-testid="new-group-summary">
    + <%= t("inspection_templates.edit.new_group") %>
  </summary>
  <div class="mt-3">
    <%= form_with(url: inspection_template_categories_path(template),
          method: :post,
          scope: :inspection_template_category,
          data: { turbo_stream: true },
          class: "flex gap-2 items-end") do |form| %>
      <div>
        <%= form.label :name, t("checklist_items.form.category"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :name,
              class: "border border-gray-300 rounded px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-transparent",
              placeholder: t("checklist_items.form.category_placeholder"),
              data: { testid: "new-group-name-input" } %>
      </div>
      <%= form.submit t("inspection_templates.edit.create_group"),
            class: "px-3 py-2 text-sm bg-blue-600 text-white rounded hover:bg-blue-700 cursor-pointer",
            data: { testid: "new-group-submit" } %>
    <% end %>
  </div>
</details>
