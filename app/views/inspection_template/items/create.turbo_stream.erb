<% category_key = item.inspection_template_category.name.to_s.parameterize.presence || "uncategorized" %>

<%= turbo_stream.append "checklist_items_#{category_key}" do %>
  <li>
    <%= render partial: "inspection_template/items/item", locals: { item: item } %>
  </li>
<% end %>

<%= turbo_stream.replace "add_item_details_#{category_key}" do %>
  <%= render partial: "inspection_template/items/add_item_details",
             locals: { template: item.inspection_template,
                       category: item.inspection_template_category } %>
<% end %>
