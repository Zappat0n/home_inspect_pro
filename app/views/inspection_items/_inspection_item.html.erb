<%= turbo_frame_tag dom_id(inspection_item) do %>
  <div class="p-4 border-b border-gray-200">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
      <div>
        <h3 class="text-lg font-medium text-gray-900">
          <%= inspection_item.checklist_item.name %>
        </h3>

        <% if inspection_item.checklist_item.description.present? %>
          <p class="mt-1 text-sm text-gray-500">
            <%= inspection_item.checklist_item.description %>
          </p>
        <% end %>
      </div>

      <div class="flex items-center gap-2 shrink-0">
        <%= button_to(
              t("inspection_items.status.ok"),
              inspection_inspection_item_path(inspection, inspection_item),
              method: :patch,
              disabled: !inspection.draft?,
              params: {
                inspection_item: {
                  status: :ok,
                },
              },
              "data-testid": "inspection-item-ok-status",
              class: "btn btn-sm #{inspection_item.ok? ? "btn-success" : "btn-inactive"}",
            ) %>

        <%= button_to(
              t("inspection_items.status.defect"),
              inspection_inspection_item_path(inspection, inspection_item),
              method: :patch,
              disabled: !inspection.draft?,
              params: {
                inspection_item: {
                  status: :defect,
                },
              },
              "data-testid": "inspection-item-defect-status",
              class: "btn btn-sm #{inspection_item.defect? ? "btn-danger" : "btn-inactive"}",
            ) %>

        <%= button_to(
              t("inspection_items.status.na"),
              inspection_inspection_item_path(inspection, inspection_item),
              method: :patch,
              disabled: !inspection.draft?,
              params: {
                inspection_item: {
                  status: :na,
                },
              },
              "data-testid": "inspection-item-na-status",
              class: "btn btn-sm #{inspection_item.na? ? "btn-na" : "btn-inactive"}",
            ) %>
      </div>
    </div>

     <% if inspection_item.defect? %>
      <div class="mt-4">
        <%= form_with(
          model: [inspection, inspection_item],
          class: "flex gap-2",
        ) do |form| %>

          <%= form.text_area(
            :comment,
            rows: 2,
            disabled: !inspection.draft?,
            "data-testid": "inspection-item-comment-textarea",
            class: "flex-1 rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm p-2 #{!inspection.draft? ? "opacity-50 cursor-not-allowed bg-gray-50" : ""}",
          ) %>

          <% if inspection.draft? %>
            <%= form.button(
              "data-testid": "inspection-item-save-comment",
              class: "btn btn-primary btn-sm",
            ) do %>
              <%= lucide_icon("save", class: "w-5 h-5") %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
