<%= turbo_frame_tag dom_id(inspection_item) do %>
  <div class="flex flex-col p-4 border-b border-gray-200" data-controller="inspection-item">
    <div class="flex flex-col items-start justify-between gap-4">
      <div class="flex flex-row justify-between w-full">
        <h3 class="text-lg font-medium text-gray-900">
          <%= inspection_item.checklist_item.name %>
        </h3>

        <% if inspection_item.checklist_item.description.present? %>
          <p class="mt-1 text-sm text-gray-500">
            <%= inspection_item.checklist_item.description %>
          </p>
        <% end %>

        <div class="flex items-start gap-2 ml-2">
          <%= render(
              partial: "inspection_items/status_buttons",
              locals: {
                inspection: inspection,
                inspection_item: inspection_item,
              },
            ) %>
        </div>
      </div>

      <% if inspection_item.defect? %>
        <%= form_with(
          model: [inspection, inspection_item],
          data: { inspection_item_target: "commentForm" },
          class: "mt-4 w-full",
        ) do |form| %>
          <%= form.text_area(
            :comment,
            rows: 2,
            disabled: !inspection.draft?,
            "data-testid": "inspection-item-comment-textarea",
            class: "form-input text-sm #{!inspection.draft? ? "opacity-50 cursor-not-allowed bg-gray-50" : ""}",
            data: { action: "blur->inspection-item#saveComment" },
          ) %>
        <% end %>
      <% end %>

      <div class="flex flex-row justify-between items-start gap-2 shrink-0 w-full">
        <div class="flex items-start gap-2 flex-wrap">
          <% photos = inspection.inspection_photos.where(checklist_item: inspection_item.checklist_item).ordered %>
          <% photos.each do |photo| %>
            <div data-testid="photo-thumbnail" class="relative">
              <%= link_to url_for(photo.photo),
                          target: "_blank",
                          class: "block" do %>
                <%= image_tag photo.photo.variant(resize_to_limit: [200, 200]),
                              class: "w-24 h-24 object-cover rounded border border-gray-200" %>
              <% end %>

              <% if inspection.draft? %>
                <%= button_to(
                      inspection_inspection_item_photo_path(inspection, inspection_item, photo),
                      method: :delete,
                      "data-testid": "photo-delete-button",
                      class: "absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-5 h-5 flex items-center justify-center text-xs hover:bg-red-600 transition-colors shadow-sm",
                    ) do %>
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
        <div data-controller="camera-bridge"
             data-camera-bridge-action-url-value="<%= inspection_inspection_item_photos_path(inspection, inspection_item) %>">
          <% if inspection_item.checklist_item.allows_photo? && inspection.draft? %>
            <%= form_with(
              url: inspection_inspection_item_photos_path(inspection, inspection_item),
              data: { controller: "photo-upload" },
            ) do |form| %>
            <%= form.label :photo,
              for: dom_id(inspection_item, :photo_upload),
              "data-camera-bridge-target": "webLabel",
              class: "btn btn-sm btn-primary cursor-pointer min-h-[44px]" do %>
              <%= lucide_icon("image-plus", class: "w-5 h-5") %>
            <% end %>
            <%= form.file_field :photo,
              id: dom_id(inspection_item, :photo_upload),
              accept: "image/*",
              class: "hidden",
              "data-camera-bridge-target": "webInput",
              data: {
                action: "change->photo-upload#upload",
                testid: "photo-upload-input",
              } %>
          <% end %>

          <button type="button"
            data-camera-bridge-target="nativeButton"
            data-action="camera-bridge#capture"
            class="btn btn-sm btn-primary min-h-[44px]"
            style="display: none">
            <%= lucide_icon("camera", class: "w-5 h-5") %>
          </button>
          <% end %>
        </div>
      </div>
    </div>

    <div id="<%= dom_id(inspection_item, :photo_upload_error) %>"></div>

  </div>
<% end %>
