<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="mb-6">
    <%= link_to t(".back"), inspection_template_path(template), class: "text-blue-600 hover:underline" %>
  </div>

  <h1 class="text-2xl font-bold mb-8"><%= t(".title", name: template.name) %></h1>

  <%= form_with(model: template, url: inspection_template_path(template), method: :patch, local: true, class: "space-y-6 mb-10") do |form| %>
    <% if template.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded p-4 mb-6">
        <h2 class="text-red-800 font-medium mb-2"><%= t("errors.messages.not_saved", count: template.errors.count, resource: template.model_name.human.downcase) %></h2>
        <ul class="list-disc list-inside text-sm text-red-700">
          <% template.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :name,
        class: "w-full border border-gray-300 rounded px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-transparent",
        data: { testid: "template-name-input" } %>
    </div>

    <div class="flex gap-4">
      <%= form.submit t(".submit"), class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
      <%= link_to t(".cancel"), inspection_template_path(template), class: "px-4 py-2 bg-gray-100 text-gray-700 rounded hover:bg-gray-200" %>
    </div>
  <% end %>

  <!-- Checklist Items -->
  <section>
    <h2 class="text-xl font-semibold mb-4"><%= t(".items_title") %></h2>

    <%= turbo_frame_tag "checklist_items", data: { controller: "item-reorder", item_reorder_reorder_url_value: reorder_inspection_template_checklist_items_path(template) } do %>
      <% grouped_items = template.checklist_items.ordered.group_by(&:category) %>

      <% if grouped_items.any? %>
        <% grouped_items.each do |category, items| %>
          <div class="mb-6">
            <h3 class="text-lg font-medium border-b pb-2 mb-3"><%= category %></h3>

            <div id="checklist_items_<%= category.parameterize %>">
              <ul class="space-y-2">
                <% items.each do |item| %>
                  <li draggable="true"
                      data-item-reorder-target="item"
                      data-item-reorder-id="<%= item.id %>"
                      data-item-reorder-position="<%= item.position %>"
                      data-action="dragstart->item-reorder#dragstart dragover->item-reorder#dragover drop->item-reorder#drop dragend->item-reorder#dragend">
                    <%= render partial: "checklist_items/checklist_item", locals: { item: item, template: template } %>
                  </li>
                <% end %>
              </ul>
            </div>

            <details class="mt-2">
              <summary class="text-sm text-blue-600 cursor-pointer hover:underline list-none">
                + <%= t(".add_item") %>
              </summary>
              <div class="mt-3">
                <%= render partial: "checklist_items/checklist_item_form", locals: { item: template.checklist_items.build(category: category), template: template, inline: false } %>
              </div>
            </details>
          </div>
        <% end %>
      <% else %>
        <p class="text-gray-500"><%= t("checklist_items.no_items") %></p>
      <% end %>
    <% end %>
  </section>
</div>
